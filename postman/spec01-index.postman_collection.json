{
  "info": {
    "name": "Spec 01 - Index (GET /posts)",
    "description": "Colección para probar la API CMS de Posts. Spec 0 (health) + Spec 1 (GET /posts index). baseUrl por defecto: http://127.0.0.1:8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('body is {status: ok}', () => {",
                  "  pm.expect(pm.response.json()).to.eql({ status: 'ok' });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Posts - Index (Spec 1)",
      "item": [
        {
          "name": "List all (defaults)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('tiene data y pagination', () => {",
                  "  pm.expect(b).to.have.property('data');",
                  "  pm.expect(b).to.have.property('pagination');",
                  "  pm.expect(b.pagination).to.have.all.keys('total','page','per_page','total_pages');",
                  "});",
                  "pm.test('per_page por defecto = 10', () => pm.expect(b.pagination.per_page).to.eql(10));",
                  "pm.test('cada post tiene los 11 campos canonicos', () => {",
                  "  const fields = ['id','title','content','excerpt','slug','status','author_id','created_at','updated_at','published_at','deleted_at'];",
                  "  if (b.data.length) pm.expect(Object.keys(b.data[0]).sort()).to.eql(fields.sort());",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Pagination (page & per_page)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?page=2&per_page=5",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                { "key": "page", "value": "2" },
                { "key": "per_page", "value": "5" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('refleja page=2 y per_page=5', () => {",
                  "  pm.expect(b.pagination.page).to.eql(2);",
                  "  pm.expect(b.pagination.per_page).to.eql(5);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Search (title + content)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?search=hola",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [{ "key": "search", "value": "hola" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Filter by status (publish)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?status=publish",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [{ "key": "status", "value": "publish" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('todos con status=publish', () => {",
                  "  b.data.forEach(p => pm.expect(p.status).to.eql('publish'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Trash visible con status=trash",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?status=trash",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [{ "key": "status", "value": "trash" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('solo posts en trash', () => {",
                  "  b.data.forEach(p => pm.expect(p.status).to.eql('trash'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Filter by author",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?author=1",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [{ "key": "author", "value": "1" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('todos del author 1', () => {",
                  "  b.data.forEach(p => pm.expect(p.author_id).to.eql(1));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Order by title asc",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?orderby=title&order=asc",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                { "key": "orderby", "value": "title" },
                { "key": "order", "value": "asc" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('titulos en orden ascendente', () => {",
                  "  const titles = b.data.map(p => p.title);",
                  "  const sorted = [...titles].sort();",
                  "  pm.expect(titles).to.eql(sorted);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid per_page (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?per_page=999",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [{ "key": "per_page", "value": "999" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('code VALIDATION_ERROR', () => {",
                  "  pm.expect(pm.response.json().code).to.eql('VALIDATION_ERROR');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid status (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?status=xyz",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [{ "key": "status", "value": "xyz" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "const b = pm.response.json();",
                  "pm.test('code VALIDATION_ERROR con detalle de status', () => {",
                  "  pm.expect(b.code).to.eql('VALIDATION_ERROR');",
                  "  pm.expect(b.details.some(d => d.field === 'status')).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid orderby (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?orderby=hackme",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [{ "key": "orderby", "value": "hackme" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "const b = pm.response.json();",
                  "pm.test('detalle de orderby', () => {",
                  "  pm.expect(b.details.some(d => d.field === 'orderby')).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
